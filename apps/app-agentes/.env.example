# URL del shell-login (identity provider central) al que redirigir
# cuando no hay sesión válida o el token es rechazado.
# Producción (Vercel): https://mesoquick-login.vercel.app
# Desarrollo (docker-compose): http://localhost:5173/
VITE_SHELL_LOGIN_URL=http://localhost:5173/

# URL base del API Gateway en la red interna de Docker (Microservicios REST)
VITE_API_GATEWAY_URL=http://broker-gateway:8000

# URL base para conexiones en tiempo real (WebSockets)
VITE_WS_URL=ws://broker-gateway:8000
